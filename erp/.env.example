# ─────────────────────────────────────────────
# ERP Brasil MVP — variáveis de ambiente
# Copie para .env e preencha os valores reais
# NUNCA commite o .env
# ─────────────────────────────────────────────

# Banco de dados
DATABASE_URL=sqlite:///./erp.db
# Para produção: postgresql://erp_user:senha@localhost:5432/erp_prod

# JWT
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# Criptografia CPF/CNPJ (Fernet — gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
