# ─── ERP Agents — Variáveis de Ambiente ───────────────────────────────────
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no repositório

# Anthropic API (obrigatório)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub (obrigatório)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=seu-usuario-github
GITHUB_REPO=erp-sistema

# AWS (para o DevOps provisionar infraestrutura)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=sa-east-1

# NF-e API (para o Especialista Fiscal — use Nuvem Fiscal ou Focus NFe)
NFE_API_KEY=...
NFE_API_URL=https://api.nuvemfiscal.com.br/v1
NFE_AMBIENTE=homologacao  # homologacao | producao

# PostgreSQL (banco local para desenvolvimento)
DATABASE_URL=postgresql://erp_user:erp_pass@localhost:5432/erp_dev
DATABASE_URL_TEST=postgresql://erp_user:erp_pass@localhost:5432/erp_test

# Redis
REDIS_URL=redis://localhost:6379/0

# Keycloak (autenticação)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=erp
KEYCLOAK_CLIENT_ID=erp-backend
KEYCLOAK_CLIENT_SECRET=...

# Configurações dos agentes
AGENT_LOG_LEVEL=INFO
AGENT_MAX_SPRINT_TOKENS=500000   # limite total de tokens por sprint
